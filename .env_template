# Copy this file to .env and replace all change-me values before running Docker.

FLASK_APP=app.py
FLASK_DEBUG=0

MYSQL_DATABASE=chromalearn
MYSQL_ROOT_PASSWORD=change-me-generate-a-long-random-password
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_USER=root
DATABASE_URL=mysql+mysqlconnector://root:change-me-generate-a-long-random-password@db:3306/chromalearn

SECRET_KEY=change-me-generate-a-long-random-secret

GRAFANA_MYSQL_USER=grafana_reader
GRAFANA_MYSQL_PASSWORD=change-me-generate-a-long-random-password

DATA_DUMP_PATH=/app/Chromalearn_Data_Dump.sql
