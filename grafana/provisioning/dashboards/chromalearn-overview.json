                       "targets":  [
                                       {
                                           "refId":  "A",
                                           "format":  "table",
                                           "rawSql":  "WITH firsts AS (SELECT user_id, MIN(DATE(completed_at)) AS first_day FROM results WHERE user_id IS NOT NULL GROUP BY user_id), returns AS (SELECT f.user_id, DATEDIFF(DATE(r.completed_at), f.first_day) AS age_days FROM firsts f JOIN results r ON r.user_id = f.user_id), total AS (SELECT COUNT(*) AS users_total FROM firsts) SELECT \u0027День 1\u0027 AS \u0027Период\u0027, ROUND(100 * COUNT(DISTINCT CASE WHEN age_days \u003e= 0 THEN user_id END) / NULLIF((SELECT users_total FROM total), 0), 1) AS \u0027% вернулись\u0027 FROM returns UNION ALL SELECT \u0027День 3\u0027, ROUND(100 * COUNT(DISTINCT CASE WHEN age_days \u003e= 2 THEN user_id END) / NULLIF((SELECT users_total FROM total), 0), 1) FROM returns UNION ALL SELECT \u0027День 7\u0027, ROUND(100 * COUNT(DISTINCT CASE WHEN age_days \u003e= 6 THEN user_id END) / NULLIF((SELECT users_total FROM total), 0), 1) FROM returns UNION ALL SELECT \u0027День 14\u0027, ROUND(100 * COUNT(DISTINCT CASE WHEN age_days \u003e= 13 THEN user_id END) / NULLIF((SELECT users_total FROM total), 0), 1) FROM returns UNION ALL SELECT \u0027День 30\u0027, ROUND(100 * COUNT(DISTINCT CASE WHEN age_days \u003e= 29 THEN user_id END) / NULLIF((SELECT users_total FROM total), 0), 1) FROM returns"
                                       }
                                   ]
