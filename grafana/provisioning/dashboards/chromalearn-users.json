                       "targets":  [
                                       {
                                           "refId":  "A",
                                           "format":  "table",
                                           "rawSql":  "SELECT bucket AS \u0027Диапазон\u0027, COUNT(*) AS \u0027Пользователей\u0027 FROM (SELECT user_id, CASE WHEN AVG(score_total) \u003c 40 THEN \u0027\u003c40\u0027 WHEN AVG(score_total) \u003c 55 THEN \u002740-55\u0027 WHEN AVG(score_total) \u003c 70 THEN \u002755-70\u0027 WHEN AVG(score_total) \u003c 80 THEN \u002770-80\u0027 WHEN AVG(score_total) \u003c 90 THEN \u002780-90\u0027 ELSE \u002790+\u0027 END AS bucket, AVG(score_total) AS avg_score FROM results WHERE user_id IS NOT NULL AND $__timeFilter(completed_at) GROUP BY user_id) x GROUP BY bucket ORDER BY MIN(avg_score)"
                                       }
                                   ]
                   },
                   {
                       "id":  7,
                       "type":  "table",
                       "title":  "Самые активные пользователи",
                       "datasource":  {
                                          "type":  "mysql",
                                          "uid":  "chromalearn-mysql"
                                      },
                       "gridPos":  {
                                       "h":  8,
                                       "w":  24,
                                       "x":  0,
                                       "y":  12
                                   },
                       "targets":  [
                                       {
                                           "refId":  "A",
                                           "format":  "table",
                                           "rawSql":  "SELECT u.login AS \u0027Логин\u0027, u.email AS \u0027Email\u0027, COUNT(r.id) AS \u0027Завершений\u0027, ROUND(AVG(r.score_total), 1) AS \u0027Средний балл\u0027, MAX(r.completed_at) AS \u0027Последнее завершение\u0027 FROM users u LEFT JOIN results r ON r.user_id = u.id AND $__timeFilter(r.completed_at) WHERE u.role = \u0027user\u0027 GROUP BY u.id, u.login, u.email ORDER BY COUNT(r.id) DESC, AVG(r.score_total) DESC LIMIT 20"
                                       }
                                   ]
                   }
