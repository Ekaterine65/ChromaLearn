                       "targets":  [
                                       {
                                           "refId":  "A",
                                           "format":  "table",
                                           "rawSql":  "SELECT ELT(WEEKDAY(r.completed_at) + 1, \u0027Пн\u0027, \u0027Вт\u0027, \u0027Ср\u0027, \u0027Чт\u0027, \u0027Пт\u0027, \u0027Сб\u0027, \u0027Вс\u0027) AS \u0027День\u0027, ROUND(100 * AVG(CASE WHEN t.level_number = 1 THEN r.score_total \u003e= 60 END), 1) AS \u0027Уровень 1\u0027, ROUND(100 * AVG(CASE WHEN t.level_number = 2 THEN r.score_total \u003e= 60 END), 1) AS \u0027Уровень 2\u0027, ROUND(100 * AVG(CASE WHEN t.level_number = 3 THEN r.score_total \u003e= 60 END), 1) AS \u0027Уровень 3\u0027 FROM results r JOIN tasks t ON t.id = r.task_id WHERE $__timeFilter(r.completed_at) GROUP BY WEEKDAY(r.completed_at), ELT(WEEKDAY(r.completed_at) + 1, \u0027Пн\u0027, \u0027Вт\u0027, \u0027Ср\u0027, \u0027Чт\u0027, \u0027Пт\u0027, \u0027Сб\u0027, \u0027Вс\u0027) ORDER BY WEEKDAY(r.completed_at)"
                                       }
                                   ]
                   },
