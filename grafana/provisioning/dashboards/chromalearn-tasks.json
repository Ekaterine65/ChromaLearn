                       "targets":  [
                                       {
                                           "refId":  "A",
                                           "format":  "table",
                                           "rawSql":  "SELECT t.id AS \u0027ID\u0027, t.title AS \u0027Задание\u0027, t.level_number AS \u0027Уровень\u0027, ROUND(AVG(r.score_total), 1) AS \u0027Итог\u0027, ROUND(AVG(r.score_harmony), 1) AS \u0027Гармония\u0027, ROUND(AVG(r.score_emotion), 1) AS \u0027Эмоция\u0027, ROUND(AVG(r.score_contrast), 1) AS \u0027Контраст\u0027, ROUND(AVG(r.score_colorblind), 1) AS \u0027Зрение\u0027, COUNT(r.id) AS \u0027Попыток\u0027 FROM tasks t JOIN results r ON r.task_id = t.id WHERE $__timeFilter(r.completed_at) GROUP BY t.id, t.title, t.level_number ORDER BY LEAST(COALESCE(AVG(r.score_harmony), 100), COALESCE(AVG(r.score_emotion), 100), COALESCE(AVG(r.score_contrast), 100), COALESCE(AVG(r.score_colorblind), 100)) ASC, AVG(r.score_total) ASC LIMIT 10"
                                       }
                                   ]
                   },
