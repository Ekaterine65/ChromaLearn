                       "targets":  [
                                       {
                                           "refId":  "A",
                                           "format":  "table",
                                           "rawSql":  "SELECT r.id AS \u0027ID результата\u0027, DATE_FORMAT(r.completed_at, \u0027%Y-%m-%d %H:%i\u0027) AS \u0027Время\u0027, COALESCE(u.login, \u0027Гость\u0027) AS \u0027Пользователь\u0027, r.score_total AS \u0027Итог\u0027, r.score_harmony AS \u0027Гармония\u0027, r.score_emotion AS \u0027Эмоция\u0027, r.score_contrast AS \u0027Контраст\u0027, r.score_colorblind AS \u0027Зрение\u0027, COALESCE(CAST(r.harmony_used AS CHAR), \u0027Не выбрано\u0027) AS \u0027Гармония выбрана\u0027, JSON_UNQUOTE(JSON_EXTRACT(r.palette_json, \u0027$[0]\u0027)) AS \u0027Цвет 1\u0027, JSON_UNQUOTE(JSON_EXTRACT(r.palette_json, \u0027$[1]\u0027)) AS \u0027Цвет 2\u0027, JSON_UNQUOTE(JSON_EXTRACT(r.palette_json, \u0027$[2]\u0027)) AS \u0027Цвет 3\u0027, JSON_UNQUOTE(JSON_EXTRACT(r.palette_json, \u0027$[3]\u0027)) AS \u0027Цвет 4\u0027, JSON_UNQUOTE(JSON_EXTRACT(r.palette_json, \u0027$[4]\u0027)) AS \u0027Цвет 5\u0027, r.palette_json AS \u0027Палитра JSON\u0027 FROM results r LEFT JOIN users u ON u.id = r.user_id WHERE r.task_id = ${task_id:raw} ORDER BY r.completed_at DESC, r.id DESC"
                                       }
                                   ],
                       "description":  "Все результаты по выбранному заданию: пользователь, баллы, тип гармонии и сохраненная палитра. Палитра появится только у новых попыток после обновления приложения."
