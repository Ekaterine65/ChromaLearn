                                   ]
                   },
                   {
                       "id":  8,
                       "type":  "table",
                       "title":  "10 заданий с самой сильной просадкой по навыкам",
                       "datasource":  {
                                          "type":  "mysql",
                                          "uid":  "chromalearn-mysql"
                                      },
                       "gridPos":  {
                                       "h":  8,
                                       "w":  24,
